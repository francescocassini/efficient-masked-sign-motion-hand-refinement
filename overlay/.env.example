# Optional credentials for institutional mirrors or public artifact repositories.
# Never commit a filled .env file.
HF_TOKEN=
HUGGINGFACE_HUB_TOKEN=

# Optional artifact repositories or dataset mirrors.
SOKENAR_MODEL_REPO=YOUR_ORG/YOUR_MODEL_REPO
SOKENAR_DATA_REPO=YOUR_ORG/YOUR_DATASET_REPO
SOKE_HF_DATASET_REPO=YOUR_ORG/YOUR_DATASET_REPO

# Local paths inside the reconstructed SOKE checkout.
SOKENAR_DATA_ROOT=datasets
SOKE_DATA_ROOT=datasets
SOKENAR_ARTIFACT_ROOT=artifacts
SOKENAR_MODEL_ROOT=artifacts/models

# Default runtime checkpoint used by configs/infer/p3_*.yaml and p5_*.yaml.
SOKENAR_CHECKPOINT=artifacts/checkpoints/p3.ckpt

# Paper checkpoint targets used by configs/paper/*.yaml.
SOKENAR_SOKE_AR_E69=artifacts/checkpoints/soke_ar_e69.ckpt
SOKENAR_MASKED_NAR_E19=artifacts/checkpoints/masked_nar_e19.ckpt
SOKENAR_MASKED_NAR_E49=artifacts/checkpoints/masked_nar_e49.ckpt

# Post-cache refinement artifacts.
SOKENAR_HANDPOLISH_CACHE=artifacts/handpolish_cache
SOKENAR_P6B_CKPT=artifacts/p6b/p6b.ckpt
SOKENAR_POSESELECT_CKPT=artifacts/poseselect/poseselect.ckpt
SOKENAR_GAINEDIT_CKPT=artifacts/gainedit/gainedit.ckpt
