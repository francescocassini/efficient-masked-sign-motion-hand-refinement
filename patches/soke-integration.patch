+def _env_int(name, default):
+    raw = os.environ.get(name, "").strip()
+    if raw == "":
+        return default
+    try:
+        return int(raw)
+    except ValueError:
+        return default
+
+
+def apply_env_overrides(cfg: OmegaConf, phase: str):
+    """Minimal env-var overrides used by scripts/run_train_infer_cycles.sh.
+
+    Re-added after 2026-04-10 strict restore which replaced this file with
+    upstream and lost orchestrator integration. Only resume + end_epoch are
+    required for cycle mode to work.
+    """
+    cfg.TRAIN.END_EPOCH = _env_int("SOKE_TRAIN_END_EPOCH", cfg.TRAIN.END_EPOCH)
+    if phase == "train":
+        train_resume = os.environ.get("SOKE_TRAIN_RESUME", "").strip()
+        if train_resume:
+            cfg.TRAIN.RESUME = train_resume
+
+    data_root = os.environ.get("SOKENAR_DATA_ROOT", "").strip()
+    if data_root:
+        cfg.DATASET.H2S.ROOT = pjoin(data_root, "How2Sign")
+        cfg.DATASET.H2S.CSL_ROOT = pjoin(data_root, "CSL-Daily")
+        cfg.DATASET.H2S.PHOENIX_ROOT = pjoin(data_root, "Phoenix_2014T")
+        cfg.DATASET.H2S.MEAN_PATH = pjoin(data_root, "CSL-Daily", "mean.pt")
+        cfg.DATASET.H2S.STD_PATH = pjoin(data_root, "CSL-Daily", "std.pt")
+
+    checkpoint = os.environ.get("SOKENAR_CHECKPOINT", "").strip()
+    if phase == "test" and checkpoint:
+        cfg.TEST.CHECKPOINTS = checkpoint
+    return cfg
+
